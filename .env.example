# Telegram (required)
TELEGRAM_BOT_TOKEN=123456:your-bot-token-from-botfather
TELEGRAM_ALLOWED_USER_ID=123456789

# NVIDIA (OpenAI-compatible generation API)
# Optional: only /genera (model-generated candidates) needs it. Leave blank to
# run manual-only: /posta still works, /genera replies that a key is required.
# Get a free "nvapi-..." key at https://build.nvidia.com (free tier available).
NVIDIA_API_KEY=
NVIDIA_MODEL=mistralai/mistral-medium-3.5-128b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# LinkedIn (placeholders, used in later slices)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/callback

# Scheduled daily rotation (optional; defaults shown)
TOPICS_PATH=topics.txt
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0

# Dry run (optional; default false). When true, tapping Publish shows exactly
# what would be posted and makes no LinkedIn call. Useful for trialing the flow
# (e.g. with /posta) without touching your real profile.
DRY_RUN=false

# Together AI image generation (optional). Powers the "Add image" button: an
# AI image is generated from the post and attached to the LinkedIn post.
# Leave blank to disable the image feature ("Add image" is hidden); the rest of
# the bot is unaffected. Get a free key at https://api.together.xyz.
TOGETHER_API_KEY=
TOGETHER_IMAGE_MODEL=Qwen/Qwen-Image
# Allow one short rendered word in the image (default false = fully text-free).
TOGETHER_IMAGE_ALLOW_TEXT=false
# Image size (default 4:5 portrait, best for the LinkedIn feed).
TOGETHER_IMAGE_WIDTH=1056
TOGETHER_IMAGE_HEIGHT=1320
